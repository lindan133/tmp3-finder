{
  "name": "tmp3-finder",
  "version": "1.2.0",
  "description": "Desktop helper for Trivia Murder Party 3 Demo — search answers from local game JSON files (Tauri, ~10 MB)",
  "author": "kankstudio.ru",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lindan133/tmp3-finder.git"
  },
  "bugs": {
    "url": "https://github.com/lindan133/tmp3-finder/issues"
  },
  "homepage": "https://kankstudio.ru",
  "keywords": [
    "trivia-murder-party-3",
    "tmp3",
    "jackbox",
    "tauri",
    "answer-finder",
    "desktop-app"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/prepare-tauri-dev.mjs && node scripts/tauri.mjs dev",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "dist": "node scripts/tauri.mjs build && node scripts/post-dist.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.6"
  }
}
